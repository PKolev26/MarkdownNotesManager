<Window x:Class="MarkdownNotesManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarkdownNotesManager.App"
        xmlns:conv="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Markdown Notes Manager"
        Height="720" Width="1200"
        Background="#FFF5F7FB">

    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF3A86FF"/>
        <SolidColorBrush x:Key="SoftBrush" Color="#FFE9EEF6"/>
        <SolidColorBrush x:Key="CardBrush" Color="White"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#FFE5EAF1"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SoftButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SoftBrush}"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0"
                Background="{StaticResource CardBrush}"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,12,0"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1">

            <StackPanel>
                <TextBlock Text="Categories"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Add"
                            Command="{Binding AddCategoryCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="60"/>

                    <Button Content="Remove"
                            Command="{Binding RemoveCategoryCommand}"
                            Style="{StaticResource SoftButton}"
                            Width="80"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         DisplayMemberPath="Name"
                         Margin="0,10,0,0"
                         BorderThickness="0"
                         Background="Transparent"/>
            </StackPanel>
        </Border>
        <Border Grid.Column="1"
                Background="{StaticResource CardBrush}"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,12,0"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1">

            <StackPanel>
                <TextBlock Text="Notes"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="New Note"
                            Command="{Binding NewNoteCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0"/>
                    <Button Content="Sort by Category"
                            Command="{Binding SortByCategoryCommand}"
                            Style="{StaticResource SoftButton}"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Notes}"
                         SelectedItem="{Binding SelectedNote}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Category.Name}" FontSize="12" Foreground="#666" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>
        <Border Grid.Column="2"
                Background="{StaticResource CardBrush}"
                CornerRadius="10"
                Padding="16"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0"
                         Text="{Binding SelectedNote.Title, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="20"
                         FontWeight="SemiBold"
                         BorderThickness="0"
                         Background="Transparent"
                         Margin="0,0,0,10"/>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Margin="0,0,0,10">

                    <ComboBox Width="220"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedNote.Category}"
                              DisplayMemberPath="Name"
                              Margin="0,0,12,0"/>

                    <Button Content="Edit"
                            Command="{Binding ShowEditCommand}"
                            Style="{StaticResource SoftButton}"
                            Width="80"/>

                    <Button Content="Preview"
                            Command="{Binding ShowPreviewCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="80"/>
                </StackPanel>

                <Grid Grid.Row="2">

                    <TextBox Text="{Binding SelectedNote.Content, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="14"
                             Padding="12"
                             BorderBrush="#FFE5EAF1"
                             BorderThickness="1"
                             Background="White"
                             Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <WebBrowser x:Name="PreviewBrowser"
                                Visibility="{Binding IsPreviewMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,12,0,0">

                    <Button Content="Delete"
                            Command="{Binding DeleteNoteCommand}"
                            Style="{StaticResource SoftButton}"
                            Width="90"/>

                    <Button Content="Save"
                            Command="{Binding SaveNoteCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="90"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>